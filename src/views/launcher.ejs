<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= settings.company_name %></title>
  <link rel="stylesheet" href="/static/style.css">
  <style>:root { --brand: <%= settings.brand_color || '#2E7D32' %>; }</style>
</head>
<body class="launcher-body" <% if (settings.bg_file_id) { %>style="background-image: linear-gradient(rgba(10,20,12,0.<%= settings.bg_dim || '45' %>), rgba(10,20,12,0.<%= settings.bg_dim || '45' %>)), url('/file/<%= settings.bg_file_id %>');"<% } %>>

  <header class="topbar">
    <div class="topbar-left">
      <% if (settings.logo_file_id) { %>
        <img class="topbar-logo" src="/file/<%= settings.logo_file_id %>" alt="">
      <% } %>
      <span class="company"><%= settings.company_name %></span>
    </div>
    <div class="topbar-right">
      <% if (user.isAdmin) { %><a class="btn-ghost" href="/admin/users">Админ-панель</a><% } %>
      <details class="user-menu">
        <summary><%= user.name %></summary>
        <div class="user-menu-body">
          <form method="POST" action="/me/password" class="inline-form">
            <input name="password" type="password" placeholder="Новый пароль (мин. 6)" minlength="6" required>
            <button type="submit">Сменить пароль</button>
          </form>
          <form method="POST" action="/logout">
            <button type="submit" class="btn-danger-link">Выйти</button>
          </form>
        </div>
      </details>
    </div>
  </header>

  <main class="launcher">
    <h2 class="greeting">Здравствуйте, <%= user.name %>!</h2>
    <% if (tiles.length === 0) { %>
      <p class="empty">Пока нет доступных программ. Обратитесь к администратору, чтобы получить доступ.</p>
    <% } %>
    <div class="grid">
      <% tiles.forEach(function(t) { %>
        <a class="tile" href="<%= t.url %>" <% if (t.open_new_tab) { %>target="_blank" rel="noopener"<% } %>>
          <div class="tile-icon"><%= t.icon %></div>
          <div class="tile-title"><%= t.title %></div>
          <div class="tile-desc"><%= t.description %></div>
        </a>
      <% }) %>
    </div>
  </main>
</body>
</html>
