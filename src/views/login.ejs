<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Вход — <%= settings.company_name %></title>
  <link rel="stylesheet" href="/static/style.css">
  <style>:root { --brand: <%= settings.brand_color || '#2E7D32' %>; }</style>
</head>
<body class="login-body" <% if (settings.bg_file_id) { %>style="background-image: linear-gradient(rgba(10,20,12,0.<%= settings.bg_dim || '45' %>), rgba(10,20,12,0.<%= settings.bg_dim || '45' %>)), url('/file/<%= settings.bg_file_id %>');"<% } %>>
  <div class="login-card">
    <% if (settings.logo_file_id) { %>
      <img class="login-logo" src="/file/<%= settings.logo_file_id %>" alt="Логотип">
    <% } %>
    <h1><%= settings.company_name %></h1>
    <p class="muted">Единое окно внутренних программ</p>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="POST" action="/login">
      <label>Логин
        <input name="login" required autofocus autocomplete="username">
      </label>
      <label>Пароль
        <input name="password" type="password" required autocomplete="current-password">
      </label>
      <button type="submit" class="btn-primary">Войти</button>
    </form>
  </div>
</body>
</html>
