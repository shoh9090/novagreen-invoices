<%- include('_header') %>

<h2>Плитки (модули)</h2>

<section class="card">
  <h3>Добавить плитку</h3>
  <form method="POST" action="/admin/tiles" class="form-row">
    <input name="title" placeholder="Название (Счета-фактуры)" required>
    <input name="description" placeholder="Короткое описание">
    <input name="icon" placeholder="Иконка-эмодзи, напр. 🧾" maxlength="8" style="max-width:140px">
    <input name="url" placeholder="https://адрес-модуля" required>
    <input name="sort_order" type="number" placeholder="Порядок (10, 20...)" style="max-width:160px">
    <label class="check"><input type="checkbox" name="open_new_tab" checked> Открывать в новой вкладке</label>
    <button type="submit" class="btn-primary">Добавить</button>
  </form>
</section>

<% tiles.forEach(function(t) { %>
  <section class="card <%= t.is_visible ? '' : 'row-inactive' %>">
    <form method="POST" action="/admin/tiles/<%= t.id %>" class="form-row">
      <input name="title" value="<%= t.title %>" required>
      <input name="description" value="<%= t.description %>">
      <input name="icon" value="<%= t.icon %>" maxlength="8" style="max-width:140px">
      <input name="url" value="<%= t.url %>" required>
      <input name="sort_order" type="number" value="<%= t.sort_order %>" style="max-width:160px">
      <label class="check"><input type="checkbox" name="open_new_tab" <%= t.open_new_tab ? 'checked' : '' %>> Новая вкладка</label>
      <button type="submit">Сохранить</button>
    </form>
    <div class="actions">
      <form method="POST" action="/admin/tiles/<%= t.id %>/toggle">
        <button type="submit"><%= t.is_visible ? 'Скрыть' : 'Показать' %></button>
      </form>
      <form method="POST" action="/admin/tiles/<%= t.id %>/delete" onsubmit="return confirm('Удалить плитку «<%= t.title %>»?')">
        <button type="submit" class="btn-danger-link">Удалить</button>
      </form>
    </div>
  </section>
<% }) %>

<%- include('_footer') %>
