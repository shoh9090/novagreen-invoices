<%- include('_header') %>

<h2>Оформление</h2>
<p class="muted">Логотип, фон и цвет меняются здесь — без программиста. Так платформа подстраивается под любую компанию.</p>

<section class="card">
  <form method="POST" action="/admin/appearance" enctype="multipart/form-data" class="form-col">
    <label>Название компании
      <input name="company_name" value="<%= settings.company_name %>" required>
    </label>

    <label>Фирменный цвет
      <input name="brand_color" type="color" value="<%= settings.brand_color || '#2E7D32' %>">
    </label>

    <label>Логотип (PNG/JPG, до 8 МБ)
      <input name="logo" type="file" accept="image/*">
    </label>
    <% if (settings.logo_file_id) { %>
      <div class="preview">
        <img src="/file/<%= settings.logo_file_id %>" alt="Текущий логотип" style="max-height:60px">
        <label class="check"><input type="checkbox" name="remove_logo" value="1"> Удалить логотип</label>
      </div>
    <% } %>

    <label>Фоновая картинка главной страницы (как в Google Chrome)
      <input name="bg" type="file" accept="image/*">
    </label>
    <% if (settings.bg_file_id) { %>
      <div class="preview">
        <img src="/file/<%= settings.bg_file_id %>" alt="Текущий фон" style="max-height:90px; border-radius:8px">
        <label class="check"><input type="checkbox" name="remove_bg" value="1"> Удалить фон</label>
      </div>
    <% } %>

    <label>Затемнение фона: <%= settings.bg_dim || '45' %>%
      <input name="bg_dim" type="range" min="0" max="85" value="<%= settings.bg_dim || '45' %>">
    </label>

    <button type="submit" class="btn-primary">Сохранить оформление</button>
  </form>
</section>

<%- include('_footer') %>
